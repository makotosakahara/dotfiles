[user]
    name = makotosakahara
    email = makoto.sakahara@gmail.com

[core]
    editor = nvim
    pager = delta

[interactive]
    diffFilter = delta --color-only

[include]
    path = ~/.config/delta/themes/catppuccin.gitconfig

[delta]
    features = catppuccin-mocha
    line-numbers = true
    hyperlinks = true

[merge]
    conflictStyle = zdiff3
