    gpgsign = true

[core]
    editor = nvim
    pager = delta

[interactive]
    diffFilter = delta --color-only

[include]
    path = ~/.config/delta/themes/catppuccin.gitconfig

[delta]
    features = catppuccin-mocha
    line-numbers = true
    hyperlinks = true

[merge]
    conflictStyle = zdiff3
