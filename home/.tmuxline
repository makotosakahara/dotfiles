# This tmux statusbar config was created by tmuxline.vim
# on Thu, 01 Nov 2018

set -g status-justify "centre"
set -g status "on"
set -g status-attr "none"
set -g message-command-bg "colour9"
set -g status-left-length "100"
set -g pane-active-border-fg "colour1"
set -g status-bg "colour8"
set -g message-command-fg "colour8"
# set -g pane-border-fg "colour9"
set -g pane-border-fg "colour8"
set -g message-bg "colour9"
set -g status-left-attr "none"
set -g status-right-attr "none"
set -g status-right-length "100"
set -g message-fg "colour8"
setw -g window-status-fg "colour15"
setw -g window-status-attr "none"
setw -g window-status-activity-bg "colour8"
setw -g window-status-activity-attr "none"
setw -g window-status-activity-fg "colour1"
setw -g window-status-separator ""
setw -g window-status-bg "colour8"
set -g status-left "#[fg=colour8,bg=colour1] #S #[fg=colour1,bg=colour8,nobold,nounderscore,noitalics]"
set -g status-right "#[fg=colour9,bg=colour8,nobold,nounderscore,noitalics]#[fg=colour8,bg=colour9] #(whoami) #[fg=colour1,bg=colour9,nobold,nounderscore,noitalics]#[fg=colour8,bg=colour1] #H "
setw -g window-status-format "#[fg=colour8,bg=colour8,nobold,nounderscore,noitalics]#[default] #I | #W #[fg=colour8,bg=colour8,nobold,nounderscore,noitalics]"
setw -g window-status-current-format "#[fg=colour8,bg=colour9,nobold,nounderscore,noitalics]#[fg=colour8,bg=colour9] #I | #W #[fg=colour9,bg=colour8,nobold,nounderscore,noitalics]"
